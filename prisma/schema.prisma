generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  password     String?
  avatar       String?
  language     String   @default("en")
  theme        String   @default("system")
  timezone     String   @default("Asia/Hebron")
  encryptedKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks        Task[]
  sleeps       Sleep[]
  expenses     Expense[]
  habits       Habit[]
  habitLogs    HabitLog[]
  moods        Mood[]
  goals        Goal[]
  contacts     Contact[]
  journals     Journal[]
  memoryNodes  MemoryNode[]
  notifications Notification[]
  settings     Settings[]
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed, cancelled
  priority    String   @default("medium") // low, medium, high, urgent
  category    String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Sleep {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  bedtime     String   // HH:mm
  wakeTime    String   // HH:mm
  duration    Float    // hours
  quality     Int      @default(3) // 1-5
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  category    String
  description String?
  date        DateTime
  type        String   @default("expense") // expense, income
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Habit {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  icon        String   @default("🎯")
  color       String   @default("#10b981")
  frequency   String   @default("daily") // daily, weekly
  target      Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  habitLogs HabitLog[]
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime
  value     Int      @default(1)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  habit Habit @relation(fields: [habitId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model Mood {
  id          String   @id @default(cuid())
  userId      String
  value       Int      // 1-10
  label       String?  // happy, sad, anxious, calm, energetic, tired
  notes       String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  category    String?  // health, finance, career, personal, education
  progress    Int      @default(0) // 0-100
  targetDate  DateTime?
  status      String   @default("active") // active, completed, paused, abandoned
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Contact {
  id          String   @id @default(cuid())
  userId      String
  name        String
  email       String?
  phone       String?
  company     String?
  role        String?
  tags        String?  // comma-separated
  notes       String?
  lastContact DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Journal {
  id          String   @id @default(cuid())
  userId      String
  title       String?
  content     String
  mood        String?
  tags        String?  // comma-separated
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model MemoryNode {
  id          String   @id @default(cuid())
  userId      String
  type        String   // person, event, place, skill, preference, fact
  key         String
  value       String
  metadata    String?  // JSON string
  confidence  Float    @default(1.0)
  source      String?  // chat, manual, inference
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String   // alert, reminder, insight, system
  title       String
  message     String
  read        Boolean  @default(false)
  actionUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Settings {
  id          String   @id @default(cuid())
  userId      String
  key         String
  value       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, key])
}

model Briefing {
  id          String   @id @default(cuid())
  userId      String
  content     String
  date        DateTime
  type        String   @default("daily") // daily, weekly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatMessage {
  id          String   @id @default(cuid())
  userId      String
  role        String   // user, assistant
  content     String
  createdAt   DateTime @default(now())
}
